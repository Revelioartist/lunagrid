# Core auth/session settings
EGLC_AUTH_SECRET=replace-with-a-long-random-secret
EGLC_AUTH_TTL_SECONDS=28800
EGLC_AUTH_PBKDF2_ITERATIONS=310000

# Session cookie settings
EGLC_AUTH_COOKIE_NAME=eglc_session
EGLC_AUTH_COOKIE_SECURE=0
EGLC_AUTH_COOKIE_SAMESITE=lax
EGLC_AUTH_COOKIE_DOMAIN=

# Store local user/auth data outside the git repo
EGLC_DATA_DIR=
EGLC_AUTH_DB=

# Tighten which frontend origins can access the API
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=
EGLC_ALLOWED_HOSTS=

# Upload / auth protection
EGLC_MAX_UPLOAD_SIZE_MB=10
EGLC_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
EGLC_AUTH_RATE_LIMIT_ATTEMPTS=10
EGLC_SIGNUP_RATE_LIMIT_ATTEMPTS=5
